# ============================================
# ঘরের খাবার চ্যাটবট - Environment Variables
# ============================================

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Facebook Page Access Token
# Get from: Facebook Developer Console > Your App > Messenger > Settings > Access Tokens
# ⚠️ Make sure this token matches the PAGE where users are messaging you
PAGE_ACCESS_TOKEN=your_page_access_token_here

# Webhook Verify Token (you choose this — must match what you set in Facebook Developer Console)
VERIFY_TOKEN=ghorer_khabar_bot_2024

# Server Port
PORT=3000
